# Debug Settings
# Cambiar a 'False' en producción
DEBUG=True
SECRET_KEY=<django-secret-key>

# Database Configuration
# Cambiar a 'true' para usar PostgreSQL, 'false' para SQLite
USE_POSTGRESQL=true

# Variables de conexión para PostgreSQL (usadas si USE_POSTGRESQL=true)
# DB_NAME: nombre de la base de datos
# DB_USER: usuario de la base de datos
# DB_PASSWORD: contraseña del usuario
# DB_HOST: host del servidor de base de datos
# DB_PORT: puerto del servidor de base de datos
DB_NAME=<postgres-database-name>
DB_USER=<postgres-username>
DB_PASSWORD=<postgres-password>
DB_HOST=<postgres-host>
DB_PORT=<postgres-port>

# Host Settings
ALLOWED_HOSTS=localhost,127.0.0.1,sisfact-demo-4447cad852f6.herokuapp.com

# Custom User Model
AUTH_USER_MODEL=inventario.Usuario

# Internationalization
LANGUAGE_CODE=en-us
TIME_ZONE=UTC
USE_TZ=True

# Static Files
STATIC_URL=/static/

########################################
# Security: Clave de cifrado de firmas #
########################################
# Clave Fernet para cifrar archivos de firma electrónica (.p12/.pfx)
# Proporcionada por el usuario
FIRMAS_KEY=<fernet-key>
